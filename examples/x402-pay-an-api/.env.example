# Copy to .env and adjust as needed.
# No real keys are used in this demo.

# Default-safe values — leave both at these defaults to keep the demo offline-only.
MOCK_MODE=true
ENABLE_REAL_CHECKOUT=false

# Documentation pointer; not used by the demo. Real Cryptorefills site:
CRYPTOREFILLS_BASE_URL=https://www.cryptorefills.com

PORT=3000

# Mock destination address for the payment requirements. Looks like a real
# Base address but is clearly fake — never put a real address here in a demo.
MOCK_RECEIVER_ADDRESS=0xMOCKReceiverAddress000000000000000000000

# Network the demo claims to settle on. Production-realistic values:
#   base, base-sepolia, ethereum, polygon, solana, tron
MOCK_NETWORK=base-sepolia

# Asset symbol (USDC by default — the de-facto x402 settlement asset).
MOCK_ASSET=USDC

# Price of the protected resource, denominated in the asset above.
MOCK_PRICE=0.01

# All values are OPTIONAL. The demo runs with zero configuration.

# Upstream x402 endpoint. Default is the public Cryptorefills x402 server.
CRYPTOREFILLS_X402_URL=https://x402.cryptorefills.com

# Per-request timeout in milliseconds. Default 5000.
CRYPTOREFILLS_X402_TIMEOUT_MS=5000

# Rate limit in requests per second. Default 1 (very conservative).
CRYPTOREFILLS_X402_RATE_LIMIT_RPS=1

# Mode: manifest (default), catalog, inspect-402.
MODE=manifest

# Country code (lowercase ISO 3166-1 alpha-2). Default us.
COUNTRY=us

# Brand name for catalog lookup. Default "Amazon.com".
BRAND=Amazon.com

# === SAFETY HARD-LOCK ===
# Setting any of the following env vars causes the demo to throw at startup.
# This demo does not implement real payment. For production payment plumbing,
# see https://github.com/cryptorefills/agents.
#
# ENABLE_REAL_PAYMENT
# PRIVATE_KEY
# WALLET_PRIVATE_KEY
# ETH_PRIVATE_KEY
# BASE_PRIVATE_KEY

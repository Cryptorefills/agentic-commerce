# All values are OPTIONAL. The demo runs with zero configuration.

# Upstream MCP endpoint. Default is the public Cryptorefills MCP server.
CRYPTOREFILLS_MCP_URL=https://api.cryptorefills.com/mcp/http

# Per-request timeout in milliseconds. Default 5000.
CRYPTOREFILLS_TIMEOUT_MS=5000

# Rate limit in requests per second. Default 1 (very conservative).
CRYPTOREFILLS_RATE_LIMIT_RPS=1

# Hard safety guard. Setting this to "true" causes the demo to throw at startup
# because real purchase plumbing is NOT implemented in this demo. Leave unset.
ENABLE_REAL_PURCHASE=false
